{
  "name": "genwel",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "clean": "rm -rf apps/*/node_modules packages/*/node_modules",
    "clean:deep": "rm -rf apps/*/node_modules packages/*/node_modules pnpm-lock.yaml && pnpm install",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.10.5",
    "typescript": "~6.0.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,md}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "**/prisma/schema.prisma": [
      "pnpm --filter @genwel/db exec prisma format"
    ]
  },
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "@sentry/cli",
      "@shopify/react-native-skia",
      "core-js",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "react": "19.2.3",
      "react-dom": "19.2.3",
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "lightningcss": "1.30.1"
    }
  }
}
