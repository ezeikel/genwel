generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// NextAuth.js models
model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String?
  emailVerified   DateTime?
  image           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  accounts        Account[]
  sessions        Session[]
  bankConnections BankConnection[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Banking models
model BankConnection {
  id             String    @id @default(cuid())
  userId         String
  providerId     String // e.g., "uk-ob-barclays"
  providerName   String // e.g., "Barclays"
  accessToken    String    @db.Text
  refreshToken   String    @db.Text
  tokenExpiresAt DateTime
  connectedAt    DateTime  @default(now())
  lastSyncedAt   DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccounts BankAccount[]

  @@map("bank_connections")
}

model BankAccount {
  id               String    @id @default(cuid())
  connectionId     String
  externalId       String // TrueLayer account_id
  accountType      String // current, savings, credit_card
  displayName      String
  currency         String    @default("GBP")
  balance          Decimal?  @db.Decimal(12, 2)
  balanceUpdatedAt DateTime?

  connection   BankConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([connectionId, externalId])
  @@map("bank_accounts")
}

model Transaction {
  id           String   @id @default(cuid())
  accountId    String
  externalId   String // TrueLayer transaction_id
  amount       Decimal  @db.Decimal(12, 2)
  currency     String   @default("GBP")
  description  String
  category     String?
  merchantName String?
  timestamp    DateTime

  account BankAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, externalId])
  @@index([accountId, timestamp])
  @@map("transactions")
}
