generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum BudgetPeriodType {
  CALENDAR_MONTH
  PAYDAY
}

enum SpendingCategory {
  SHOPPING
  GROCERIES
  EATING_OUT
  BILLS
  TRANSPORT
  ENTERTAINMENT
  HEALTH
  PERSONAL_CARE
  EDUCATION
  TRANSFER
  CASH
  INCOME
  FEES
  SAVINGS
  REMITTANCES
  SUBSCRIPTIONS
  OTHER
}

// NextAuth.js models
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Billing identity (source-of-truth contract). stripeCustomerId is set once a
  // Stripe customer exists; revenuecatUserId is the RevenueCat app_user_id (=
  // our userId) so a mobile purchase links to the same User. Both Stripe (web)
  // and RevenueCat (mobile) write into the shared Subscription table below.
  stripeCustomerId String? @unique
  revenuecatUserId String? @unique

  accounts        Account[]
  sessions        Session[]
  bankConnections BankConnection[]
  budgetConfig    BudgetConfig?
  aiInsights      AiInsight[]
  subscriptions   Subscription[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Banking models
model BankConnection {
  id             String    @id @default(cuid())
  userId         String
  providerId     String // e.g., "uk-ob-barclays"
  providerName   String // e.g., "Barclays"
  accessToken    String    @db.Text
  refreshToken   String    @db.Text
  tokenExpiresAt DateTime
  connectedAt    DateTime  @default(now())
  lastSyncedAt   DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccounts BankAccount[]

  @@map("bank_connections")
}

model BankAccount {
  id               String    @id @default(cuid())
  connectionId     String
  externalId       String // TrueLayer account_id
  accountType      String // current, savings, credit_card
  displayName      String
  currency         String    @default("GBP")
  balance          Decimal?  @db.Decimal(12, 2)
  balanceUpdatedAt DateTime?

  connection   BankConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([connectionId, externalId])
  @@map("bank_accounts")
}

model Transaction {
  id           String            @id @default(cuid())
  accountId    String
  externalId   String // TrueLayer transaction_id
  amount       Decimal           @db.Decimal(12, 2)
  currency     String            @default("GBP")
  description  String
  category     String?
  merchantName String?
  aiCategory   SpendingCategory?
  timestamp    DateTime

  account BankAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, externalId])
  @@index([accountId, timestamp])
  @@index([accountId, aiCategory, timestamp])
  @@map("transactions")
}

// Budgeting models
model BudgetConfig {
  id         String           @id @default(cuid())
  userId     String           @unique
  periodType BudgetPeriodType @default(CALENDAR_MONTH)
  paydayDate Int? // Day of month (1-31) for payday budgets
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  budgets Budget[]

  @@map("budget_configs")
}

model Budget {
  id        String           @id @default(cuid())
  configId  String
  category  SpendingCategory
  amount    Decimal          @db.Decimal(12, 2)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  config BudgetConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, category])
  @@map("budgets")
}

model AiInsight {
  id        String   @id @default(cuid())
  userId    String
  type      String // spending_trend, anomaly, saving_tip, budget_suggestion
  title     String
  body      String   @db.Text
  metadata  Json?
  read      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("ai_insights")
}

// --- Subscriptions (DB = source of truth, shared by Stripe web + RevenueCat mobile) ---
//
// A `subscriptions` row is a normalized local read-cache of the provider's
// truth, keyed by (platform, externalId), kept in sync ONLY by webhooks.
// Entitlement checks read this table (never Stripe/RevenueCat live). Both
// providers map their events into the same SubscriptionStatus/PlanName enums,
// so one helper (getEntitlements) answers correctly for web and mobile.

model Subscription {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  platform   SubscriptionPlatform @default(STRIPE)
  externalId String               @unique // Stripe subscription ID OR RevenueCat txn ID

  planName      PlanName
  billingPeriod BillingPeriod
  status        SubscriptionStatus

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime
  trialStart         DateTime?
  trialEnd           DateTime?
  cancelledAt        DateTime?
  gracePeriodEnd     DateTime?

  storeProductId String? // e.g. RevenueCat product id "genwel_pro_monthly"
  metadata       Json?

  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  events    SubscriptionEvent[]

  @@index([userId])
  @@index([platform, externalId])
  @@map("subscriptions")
}

// Append-only audit log of every subscription lifecycle change (both providers).
model SubscriptionEvent {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  eventType       SubscriptionEventType
  platform        SubscriptionPlatform
  externalEventId String?               @unique // Stripe/RevenueCat event id

  previousStatus SubscriptionStatus?
  newStatus      SubscriptionStatus?
  previousPlan   PlanName?
  newPlan        PlanName?

  rawPayload  Json?
  processedAt DateTime @default(now())

  @@index([subscriptionId])
  @@map("subscription_events")
}

// Idempotency: every processed webhook event id is recorded so re-delivered
// events (Stripe or RevenueCat) are skipped.
model WebhookEvent {
  id          String               @id // Stripe event id OR RevenueCat event id
  platform    SubscriptionPlatform
  eventType   String
  processedAt DateTime             @default(now())

  @@map("webhook_events")
}

// Genwel has one paid tier (PRO). FREE is the absence of an active subscription,
// not a stored plan. Reserve room for a future tier here if needed.
enum PlanName {
  PRO
}

enum BillingPeriod {
  MONTHLY
  ANNUAL
}

// Normalized status both Stripe and RevenueCat map into.
enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
  PAUSED
}

enum SubscriptionPlatform {
  STRIPE // web
  REVENUECAT // mobile (App Store / Play Store)
}

enum SubscriptionEventType {
  TRIAL_STARTED
  SUBSCRIPTION_STARTED
  RENEWAL_SUCCESS
  RENEWAL_FAILED
  PLAN_UPGRADED
  PLAN_DOWNGRADED
  CANCELLATION_SCHEDULED
  CANCELLED
  REACTIVATED
  BILLING_ISSUE_DETECTED
  BILLING_ISSUE_RESOLVED
  GRACE_PERIOD_STARTED
  GRACE_PERIOD_EXPIRED
  EXPIRED
  TRANSFERRED
}
