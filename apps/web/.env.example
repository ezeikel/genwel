# Database (Neon)
DATABASE_URL=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Mobile bearer-token signing (falls back to NEXTAUTH_SECRET when omitted)
MOBILE_AUTH_SECRET=

# Email (Resend)
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=

# OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
# Comma-separated native bundle IDs accepted by mobile Sign in with Apple
APPLE_BUNDLE_IDS=com.chewybytes.genwel.app,com.chewybytes.genwel.app.internal,com.chewybytes.genwel.app.dev

FACEBOOK_CONSUMER_APP_ID=
FACEBOOK_CONSUMER_APP_SECRET=

# TrueLayer
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=
TRUELAYER_REDIRECT_URI=http://localhost:3000/api/banking/callback
NEXT_PUBLIC_TRUELAYER_ENV=sandbox

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=genwel.com

# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=chewybytes
SENTRY_PROJECT=genwel-web
SENTRY_AUTH_TOKEN=

# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-17
SANITY_API_TOKEN=
SANITY_REVALIDATE_SECRET=

# AI Generation
# OpenAI — transaction categorization (GPT-5.6 Luna) + blog text (GPT-4o)
OPENAI_API_KEY=
# Anthropic — financial insights + budget suggestions (Claude Sonnet 5)
ANTHROPIC_API_KEY=
# Google — vision/image evaluation + blog image generation (Gemini 3 Pro)
GOOGLE_GENERATIVE_AI_API_KEY=
PEXELS_API_KEY=

# Security
CRON_SECRET=

# Background worker (Hetzner) — TrueLayer sync + AI categorization
# URL of the genwel-worker service (e.g. http://157.90.168.197:3080).
GENWEL_WORKER_URL=
# Shared bearer secret; MUST match the worker's WORKER_SECRET on the box.
WORKER_SECRET=

# Stripe (web subscriptions) — DB is the source of truth via the webhook.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# The two Pro Prices from the Genwel Stripe Product (£6.99/mo, £54.99/yr).
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_PRO_ANNUAL=

# RevenueCat (mobile subscriptions). Both values are server-only. The REST key
# must be a v1 Secret API key (sk_...), never a public/EXPO_PUBLIC SDK key.
REVENUECAT_SECRET_API_KEY=
REVENUECAT_WEBHOOK_AUTH=

# Mobile app store badges (feature flag — hidden until the apps are published).
NEXT_PUBLIC_SHOW_APP_STORE_BADGES=false
NEXT_PUBLIC_APP_STORE_URL=
NEXT_PUBLIC_PLAY_STORE_URL=
