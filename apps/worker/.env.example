# --- HTTP server (Hetzner box) ---
# Port the Hono server binds (0.0.0.0). MUST be set explicitly on the box — the
# shared Hetzner runbook allocates 3080 to Genwel. See HETZNER_BOX.md.
PORT=3080
# Shared secret gating /sync/* AND /generate/*. The web app sends it as
# `Authorization: Bearer <WORKER_SECRET>`. MUST match the web app's value
# (Vercel + apps/web/.env.local). Unset = open (local dev only).
WORKER_SECRET=

# --- Database (shared Prisma client @genwel/db) ---
# Neon pooled URL. On the box this points at the PRODUCTION branch
# (br-hidden-violet-ahpayw2m). Locally it can point at the dev branch.
DATABASE_URL=

# --- TrueLayer (Open Banking data API — transaction sync) ---
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=
# 'sandbox' or 'production' — switches TrueLayer base URLs + providers.
NEXT_PUBLIC_TRUELAYER_ENV=production

# --- AI (transaction categorization + blog generation) ---
# OpenAI — categorization (gpt-5.6-luna) AND the blog featured-image
# gpt-image-2 fallback. Without it the blog still publishes, just without an
# image when no Pexels photo clears the vision judge.
OPENAI_API_KEY=
# Anthropic — blog meta + body + never-dry topic ideation (Claude Sonnet 5).
ANTHROPIC_API_KEY=
# Google — blog image RELEVANCE evaluation / vision judge (Gemini).
GOOGLE_GENERATIVE_AI_API_KEY=

# --- Sanity (blog CMS write path) ---
# The worker publishes generated posts into Sanity. Same values the web app
# reads as NEXT_PUBLIC_SANITY_* / SANITY_API_TOKEN, under plain names here.
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2025-01-17
# Write token (Editor role) — required to create posts + upload image assets.
SANITY_WRITE_TOKEN=

# --- Pexels (blog featured-image stock search, first choice) ---
# https://www.pexels.com/api/ — the blog tries Pexels photos (judged by the
# Gemini vision judge) before falling back to gpt-image-2. Optional: unset =
# always generate.
PEXELS_API_KEY=

# --- Sentry (error reporting) ---
# genwel-worker project DSN. Omit to disable reporting.
SENTRY_DSN=
