# Genwel mobile environment surface. EXPO_PUBLIC_* values are embedded in the
# app bundle and must never contain private/server credentials.

# development | preview | production (normally set by eas.json)
EXPO_PUBLIC_ENVIRONMENT="development"

# API environment matrix:
# - development defaults to the local Next.js API (iOS: localhost:3000;
#   Android emulator: 10.0.2.2:3000), whose .env.local uses Neon development
#   and TrueLayer sandbox.
# - preview and production use https://www.genwel.com (set in eas.json), whose
#   Vercel production environment uses Neon production and TrueLayer live.
# Override only when intentionally testing another development API.
# EXPO_PUBLIC_API_URL="http://localhost:3000"

# RevenueCat public SDK keys.
# - development: use the project's `test_` Test Store key for simulator tests
# - preview/production: use platform `appl_` / `goog_` keys only
# Never put REVENUECAT_SECRET_API_KEY or webhook authorization values here.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=""
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=""

# Native OAuth providers (optional in local development).
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=""
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=""
EXPO_PUBLIC_FACEBOOK_APP_ID=""
EXPO_PUBLIC_FACEBOOK_CLIENT_TOKEN=""
