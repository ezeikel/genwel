{
  "name": "@genwel/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "clean": "git clean -xdf .expo node_modules",
    "start": "expo start",
    "dev": "expo start --dev-client",
    "dev:android": "expo start --android",
    "dev:ios": "expo start --ios",
    "web": "expo start --web",
    "install-skia": "install-skia",
    "prebuild": "pnpm install-skia && expo prebuild",
    "prebuild:ios": "pnpm install-skia && expo prebuild --platform ios --clean",
    "prebuild:android": "pnpm install-skia && expo prebuild --platform android --clean",
    "ios": "expo run:ios --no-build-cache",
    "android": "expo run:android --no-build-cache",
    "build:ios": "pnpm prebuild:ios && pnpm ios",
    "build:android": "pnpm prebuild:android && pnpm android",
    "build": "expo export",
    "eas:build:development": "eas build --profile development",
    "eas:build:preview": "eas build --profile preview",
    "eas:build:production": "eas build --profile production",
    "eas:update:development": "eas update --channel development --environment development",
    "eas:update:preview": "eas update --channel preview --environment preview",
    "eas:update:production": "eas update --channel production --environment production",
    "eas:release:ios": "eas build --profile production --platform ios --auto-submit",
    "eas:release:android": "eas build --profile production --platform android --auto-submit",
    "eas:submit:production": "eas submit --profile production",
    "check-types": "tsc --noEmit",
    "env:pull": "eas env:pull --environment development",
    "doctor": "npx react-doctor@latest",
    "test": "echo \"no unit tests in apps/mobile yet\" && exit 0"
  },
  "dependencies": {
    "@expo/dom-webview": "~57.0.0",
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo/metro-runtime": "~57.0.3",
    "@ai-sdk/react": "^4.0.27",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/pro-duotone-svg-icons": "^7.2.0",
    "@fortawesome/pro-regular-svg-icons": "^7.2.0",
    "@fortawesome/pro-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-native-fontawesome": "^1.0.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@shopify/react-native-skia": "2.6.2",
    "@shopify/flash-list": "2.0.2",
    "@swmansion/react-native-bottom-sheet": "^0.15.3",
    "@tanstack/react-form": "^1.33.0",
    "ai": "^6.0.208",
    "expo": "~57.0.4",
    "expo-apple-authentication": "~57.0.0",
    "expo-application": "^57.0.0",
    "expo-blur": "~57.0.0",
    "expo-build-properties": "~57.0.3",
    "expo-constants": "~57.0.3",
    "expo-crypto": "~57.0.0",
    "expo-dev-client": "~57.0.5",
    "expo-font": "~57.0.0",
    "expo-glass-effect": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-notifications": "~57.0.3",
    "expo-router": "~57.0.4",
    "expo-secure-store": "~57.0.0",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-updates": "~57.0.6",
    "expo-web-browser": "~57.0.0",
    "nativewind": "5.0.0-preview.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-css": "^3.0.4",
    "react-native-fbsdk-next": "^13.4.3",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-graph": "^1.2.0",
    "react-native-purchases": "^10.4.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.10.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@react-native/metro-config": "0.86.0",
    "@tailwindcss/postcss": "^4",
    "@types/react": "19.2.14",
    "lightningcss": "1.30.1",
    "postcss": "^8",
    "tailwindcss": "^4",
    "typescript": "~6.0.3"
  }
}
