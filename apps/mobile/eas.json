{
  "cli": {
    "promptToConfigurePushNotifications": false,
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "ios": {
        "resourceClass": "m-medium",
        "image": "macos-tahoe-26.4-xcode-26.4"
      },
      "android": {
        "image": "latest"
      },
      "channel": "base"
    },
    "development": {
      "extends": "base",
      "environment": "development",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_ENVIRONMENT": "development",
        "EXPO_PUBLIC_API_URL": "http://localhost:3000"
      },
      "autoIncrement": false
    },
    "preview": {
      "extends": "base",
      "environment": "preview",
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_ENVIRONMENT": "preview",
        "EXPO_PUBLIC_API_URL": "https://www.genwel.com"
      },
      "autoIncrement": true
    },
    "production": {
      "extends": "base",
      "environment": "production",
      "distribution": "store",
      "developmentClient": false,
      "env": {
        "EXPO_PUBLIC_ENVIRONMENT": "production",
        "EXPO_PUBLIC_API_URL": "https://www.genwel.com"
      },
      "autoIncrement": true,
      "channel": "production"
    },
    "prod-apk": {
      "extends": "base",
      "environment": "production",
      "distribution": "internal",
      "developmentClient": false,
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_ENVIRONMENT": "production",
        "EXPO_PUBLIC_API_URL": "https://www.genwel.com"
      },
      "autoIncrement": true,
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "production"
      },
      "ios": {
        "appleId": "developer@chewybytes.com",
        "appleTeamId": "HGX827L49J",
        "ascAppId": "TODO_ASC_APP_ID"
      }
    }
  }
}
